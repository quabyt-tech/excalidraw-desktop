{
  "productName": "Excalidraw Desktop",
  "version": "0.4.2",
  "identifier": "com.quabyt.excalidraw-desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Excalidraw Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data: blob:",
        "font-src": "'self' data:",
        "worker-src": "'self' blob:",
        "connect-src": "'self' ipc: http://ipc.localhost https://libraries.excalidraw.com",
        "frame-src": "https://www.youtube.com https://player.vimeo.com https://www.figma.com https://link.excalidraw.com https://*.simplepdf.eu https://stackblitz.com https://giphy.com",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Quabyt",
    "resources": ["../THIRD-PARTY-NOTICES.md"],
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "dmg", "app", "deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": ["English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "fileAssociations": [
      {
        "ext": ["excalidraw"],
        "mimeType": "application/json",
        "description": "Excalidraw Drawing"
      }
    ],
    "shortDescription": "A lightweight desktop app for Excalidraw",
    "longDescription": "Excalidraw Desktop is a native wrapper around Excalidraw, the virtual whiteboard for sketching hand-drawn like diagrams."
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["excalidraw-desktop"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4Rjg1NDUwQkUzNDlGRTkKUldUcG56UytVRlQ0U0ZSb3dMTDAvOGhnbXYwV0VBRlJCZHhudk84NTE3dHJrYzlQQWZIZi9EUlgK",
      "endpoints": [
        "https://github.com/quabyt-tech/excalidraw-desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
